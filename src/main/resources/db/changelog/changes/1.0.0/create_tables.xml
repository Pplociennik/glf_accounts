<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- ############################################################################################################### -->

    <!--  ############## PPGLF-28 ##############  -->

    <!-- Create table user_details -->
    <changeSet id="17.08.2025 00:00:00" author="pplociennik">
        <comment>Creates the table 'user_details'.</comment>
        <createTable tableName="user_details">
            <column name="id" type="BINARY(16)">
                <constraints primaryKey="true" nullable="false" unique="true"/>
            </column>
            <column name="user_id" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="name" type="VARCHAR(255)"/>
            <column name="email" type="VARCHAR(255)"/>
            <column name="description" type="VARCHAR(1000)"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(255)" defaultValue="SYSTEM">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_by" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Create the table accounts_user_session_details -->
    <changeSet id="17.08.2025 00:10:00" author="pplociennik">
        <comment>Creates the table 'accounts_user_session_details'.</comment>
        <createTable tableName="accounts_user_session_details">
            <column name="id" type="BINARY(16)">
                <constraints primaryKey="true" nullable="false" unique="true"/>
            </column>
            <column name="session_id" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="refresh_token" type="VARCHAR(1000)">
                <constraints nullable="false"/>
            </column>
            <column name="authenticated_user_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="location" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="device" type="VARCHAR(255)"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(255)" defaultValue="SYSTEM">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Indexes for better performance. -->
        <createIndex tableName="accounts_user_session_details" indexName="idx_session_details_session_id">
            <column name="session_id"/>
        </createIndex>

        <createIndex tableName="accounts_user_session_details" indexName="idx_session_details_authenticated_user_id">
            <column name="authenticated_user_id"/>
        </createIndex>
    </changeSet>

    <!-- ############################################################################################################### -->

</databaseChangeLog>
